# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3005
PUBLIC_WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://emc:emc_dev_password@localhost:5432/emc?schema=public

# ── Secrets (production: AWS Secrets Manager / KMS — never commit real values)
JWT_SECRET=change-me-64-random-chars
# 32-byte hex key for AES-256-GCM field encryption
DATA_ENCRYPTION_KEY=6f1d0e9b2c4a5d7e8f0a1b2c3d4e5f60718293a4b5c6d7e8f90a1b2c3d4e5f60
SEARCH_HMAC_KEY=change-me-hmac-key

# ── Blockchain anchoring (Ethereum Sepolia — same contract as prototype) ─────
CHAIN_ENABLED=false
CHAIN_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CHAIN_CONTRACT_ADDRESS=0x52748C170EE85FF4f15E677b909f5c154F83e2CD
# Wallet of a contract-verified doctor/issuer (funded with Sepolia ETH)
CHAIN_ISSUER_PRIVATE_KEY=
CHAIN_EXPLORER_TX_BASE=https://sepolia.etherscan.io/tx/

# ── Fraud engine ─────────────────────────────────────────────────────────────
FRAUD_MAX_MC_PER_DOCTOR_PER_DAY=60
